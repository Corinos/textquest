::Glossary

::QuestGlobal <<declare>>
$player = null
$party = (array:)
$year = 1618
$season = "Sea Season"
$clanResources = (dm:)[
  "wealth": 17,
  "warriors": 16,
  "magic": 15,
  "reputation": 14,
  "allies": 14
]
$factionStanding = (dm:)[
  "freeSartar": 10,
  "eyeOfHurricane": 10,
  "conqueringStorm": 10,
  "wolfskinners": 10,
  "moonWinds": 10
]
$arcProgress = (dm:)[
  "thorvald": 0,
  "erlana": 0,
  "rok": 0,
  "asvith": 0,
  "kara": 0
]
$endingType = null
$gameLog = (array:)
</div>

::QuestFunctions [nosave]
<<macro "roll">>
<<set _abil = $args[0]>>
<<set _resist = $args[1]>>
<<set _charDie = (random: 1, 20)>>
<<set _resistDie = (random: 1, 20)>>
<<set _result = "mixed">>
<<if _charDie == 20>>
<<set _result = "critical">>
<<elseif _charDie == 1>>
<<set _result = "fumble">>
<<elseif _charDie >= 11>>
<<if _resistDie >= 11>>
<<set _result = "mixed">>
<<else>>
<<set _result = "victory">>
<</if>>
<<else>>
<<if _resistDie >= 11>>
<<set _result = "defeat">>
<<else>>
<<set _result = "mixed">>
<</if>>
<</if>>
<</if>>
<<return (dm:)[
  "charDie": _charDie,
  "resistDie": _resistDie,
  "result": _result,
  "ability": _abil,
  "resistance": _resist
]>>
</macro>>

<<macro "simpleRoll">>
<<set _abil = $args[0]>>
<<set _tn = 11>>
<<if $args[1]>>
<<set _tn = $args[1]>>
<</if>>
<<set _roll = (random: 1, 20)>>
<<set _result = "fail">>
<<if _roll >= _tn>>
<<set _result = "success">>
<</if>>
<<if _roll >= 17>>
<<set _result = "great">>
<</if>>
<<return (dm:)[
  "roll": _roll,
  "result": _result,
  "TN": _tn
]>>
</macro>>

<<macro "factionRoll">>
<<set _abil = $args[0]>>
<<set _tn = 11>>
<<if $args[1]>>
<<set _tn = $args[1]>>
<</if>>
<<set _bonus = 0>>
<<if $player.cult == "Orlanth Adventurous">>
<<if $factionStanding.freeSartar >= 15>>
<<set _bonus = 2>>
<</if>>
<<elseif $player.cult == "Ernalda">>
<<if $factionStanding.eyeOfHurricane >= 15>>
<<set _bonus = 2>>
<</if>>
<<elseif $player.cult == "Storm Bull">>
<<if $factionStanding.wolfskinners >= 15>>
<<set _bonus = 2>>
<</if>>
<<elseif $player.cult == "Orlanth Rex">>
<<if $factionStanding.wolfskinners >= 15>>
<<set _bonus = 2>>
<</if>>
<<elseif $player.cult == "Humakt">>
<<if $factionStanding.eyeOfHurricane >= 15>>
<<set _bonus = 2>>
<</if>>
<</if>>
<<set _roll = (random: 1, 20) + _bonus>>
<<set _result = "fail">>
<<if _roll >= _tn>>
<<set _result = "success">>
<</if>>
<<if _roll >= 17>>
<<set _result = "great">>
<</if>>
<<return (dm:)[
  "roll": _roll,
  "bonus": _bonus,
  "result": _result,
  "TN": _tn
]>>
</macro>>

<<macro "updateFaction">>
<<set _faction = $args[0]>>
<<set _amount = $args[1]>>
<<set _current = $factionStanding[_faction]>>
<<set _new = _current + _amount>>
<<if _new > 20>>
<<set _new = 20>>
<</if>>
<<if _new < 0>>
<<set _new = 0>>
<</if>>
<<set $factionStanding[_faction] = _new>>
</macro>>

<<macro "updateResources">>
<<set _resource = $args[0]>>
<<set _amount = $args[1]>>
<<set _current = $clanResources[_resource]>>
<<set _new = _current + _amount>>
<<if _new < 0>>
<<set _new = 0>>
<</if>>
<<set $clanResources[_resource] = _new>>
</macro>>

<<macro "checkQuestUnlock">>
<<set _questId = $args[0]>>
<<set _unlocked = false>>
<<if _questId == "huntJogar">>
<<if $factionStanding.freeSartar >= 10>>
<<set _unlocked = true>>
<</if>>
<</if>>
<<if _questId == "husbandTruth">>
<<if $arcProgress.kara >= 3>>
<<set _unlocked = true>>
<</if>>
<</if>>
<<if _questId == "elevenLights">>
<<if $year >= 1624>>
<<set _unlocked = true>>
<</if>>
<</if>>
<<if _questId == "liberation">>
<<if $factionStanding.freeSartar + $factionStanding.wolfskinners >= 25>>
<<set _unlocked = true>>
<</if>>
<</if>>
<<return _unlocked>>
</macro>>

<<macro "advanceArc">>
<<set _character = $args[0]>>
<<set _amount = 1>>
<<if $args[1]>>
<<set _amount = $args[1]>>
<</if>>
<<set _current = $arcProgress[_character]>>
<<set $arcProgress[_character] = _current + _amount>>
</macro>>

<<macro "checkEnding">>
<<set _ending = null>>
<<if $factionStanding.freeSartar >= 20 and $factionStanding.wolfskinners >= 15>>
<<set _ending = "freedom">>
<<elseif $factionStanding.moonWinds >= 20>>
<<set _ending = "collaboration">>
<<elseif $clanResources.wealth <= 5>>
<<set _ending = "exile">>
<</if>>
<<set $endingType = _ending>>
<<return _ending>>
</macro>>

::Start
The wind sweeps down from the Quivin Mountains, carrying the scent of snow. You stand at the gates of Red Cow Fort, watching the gray sky—knowing that the coming years will test everything your clan holds dear.

But first, you must choose your hero.

[[Select Your Hero]]

::Select Your Hero
Where do your loyalties lie? Choose your character:

<<if $player is null>>

* [[Thorvald Storm-Speaker->Character Select: Thorvald]]
* [[Erlana Earth-Keeper->Character Select: Erlana]]
* [[Rok Thunder-Mouth->Character Select: Rok]]
* [[Asvith Silver-Step->Character Select: Asvith]]
* [[Kara Silent-Blade->Character Select: Kara]]

<</if>>

::Character Select: Thorvald
<<unset $player>>
<<set $player = (dm:)[
  "name": "Thorvald Storm-Speaker",
  "bloodline": "Tormakting",
  "cult": "Orlanth Adventurous",
  "abilities": (dm:)[
    "Spear Fighting": 17,
    "Shield Wall": 16,
    "Battle Cry": 15,
    "Axe Mastery": 14,
    "Fearless": 14,
    "Loyalty to Clan": 16,
    "Command": 15,
    "Athletics": 14,
    "Awareness": 13,
    "Endurance": 15,
    "Intimidation": 14,
    "Oral History": 12,
    "Riding": 11
  ],
  "keywords": (dm:)[
    "Storm Warrior": 17
  ],
  "flaws": (dm:)[
    "Oath-Breaker Hunt": 3,
    "Reckless Courage": 2
  ],
  "equipment": (dm:)[
    "Iron Spear": 15,
    "Wooden Shield": 14,
    "Chainmail": 13,
    "War Axe": 14
  ],
  "hp": 18,
  "maxHp": 18,
  "description": "A housecarl sworn to defend the Red Cow clan. His brother was killed by Lunar soldiers. He serves as Broddi's personal guard, and his hatred of the Lunar Empire burns like wildfire."
]>>
You are Thorvald Storm-Speaker, a housecarl sworn to defend the chieftain. Your brother died when the Lunars came—you watched him fall, and you swore an oath: no more foreign swords on Red Cow land.

[[Begin the Campaign]]

